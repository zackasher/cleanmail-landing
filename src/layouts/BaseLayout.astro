---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
export interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = "Cleanmail reads the email so you don't have to. Every newsletter, reminder, and update, organized by person and activity, with every date on your calendar.",
  image = "/logo.png",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={image} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style is:global>
    :root{
      --purple:#4A6FE3; --orange:#E88C30; --green:#66EE78;
      --navy:#1b2236; --ink:#3a4156; --muted:#7a8196;
      --card:#f7f9ff; --line:#e6ebf6;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:"Helvetica Neue",Helvetica,-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;color:var(--navy);background:#fff;-webkit-font-smoothing:antialiased}
    .page{
      position:relative;min-height:100vh;
      background:
        radial-gradient(1250px 1250px at 0% 0%, rgba(74,111,227,.34) 0%, rgba(74,111,227,.13) 15%, rgba(74,111,227,0) 58%),
        radial-gradient(1250px 1250px at 100% 0%, rgba(74,111,227,.32) 0%, rgba(74,111,227,.12) 15%, rgba(74,111,227,0) 58%),
        radial-gradient(1480px 1480px at 0% 100%, rgba(232,140,48,.42) 0%, rgba(232,140,48,.17) 16%, rgba(232,140,48,0) 62%),
        radial-gradient(1480px 1480px at 100% 100%, rgba(232,140,48,.40) 0%, rgba(232,140,48,.16) 16%, rgba(232,140,48,0) 62%),
        #ffffff;
    }
  </style>
</head>
<body>
  <div class="page">
    <Nav />
    <slot />
    <Footer />
  </div>
</body>
</html>
