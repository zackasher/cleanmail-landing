---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
export interface Props {
  title: string;
  description?: string;
  image?: string;
  faqSchema?: unknown;
}
const {
  title,
  description = "Stop reading every email. Cleanmail turns the school, camp, and sports noise into one clean digest, organized by person and activity, with every date already on your calendar.",
  image = "/og.png",
  faqSchema,
} = Astro.props;

const canonicalPath = Astro.url.pathname
  .replace(/index\.html$/, "")
  .replace(/\.html$/, "")
  .replace(/(.+)\/$/, "$1");
const canonicalURL = new URL(canonicalPath || "/", "https://cleanmailapp.com").href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="j0driezVtY4Wr0F1EeHI5-nBMDQfm_KR4BI9JMa1Ggo" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={new URL(image, "https://cleanmailapp.com").href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Cleanmail. Stop reading every email, just read the words that matter." />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:image" content={new URL(image, "https://cleanmailapp.com").href} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Cleanmail",
    "url": "https://cleanmailapp.com",
    "logo": "https://cleanmailapp.com/logo.png"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Cleanmail",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "iOS",
    "url": "https://cleanmailapp.com",
    "description": "Cleanmail turns school, camp, and sports emails into one clean digest, organized by person and activity, with every date already on your calendar."
  })} />
  <ClientRouter />
  <style is:global>
    :root{
      --purple:#4A6FE3; --orange:#E88C30; --green:#66EE78; --teal:#5dc4b8;
      --navy:#1b2236; --ink:#3a4156; --muted:#7a8196;
      --card:#f7f9ff; --line:#e6ebf6;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:"Helvetica Neue",Helvetica,-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;color:var(--navy);background:#fff;-webkit-font-smoothing:antialiased}
    .page{
      position:relative;min-height:100vh;display:flow-root;
      background:
        radial-gradient(1250px 1250px at 0% 0%, rgba(74,111,227,.34) 0%, rgba(74,111,227,.13) 15%, rgba(74,111,227,0) 58%),
        radial-gradient(1250px 1250px at 100% 0%, rgba(74,111,227,.32) 0%, rgba(74,111,227,.12) 15%, rgba(74,111,227,0) 58%),
        radial-gradient(1480px 1480px at 0% 100%, rgba(232,140,48,.42) 0%, rgba(232,140,48,.17) 16%, rgba(232,140,48,0) 62%),
        radial-gradient(1480px 1480px at 100% 100%, rgba(232,140,48,.40) 0%, rgba(232,140,48,.16) 16%, rgba(232,140,48,0) 62%),
        #ffffff;
    }
  </style>
</head>
<body>
  <div class="page">
    <Nav />
    <slot />
    <Footer />
  </div>
  <script>
    function playHeroVideo() {
      document.querySelectorAll("video.hero-video").forEach((v) => {
        const p = v.play();
        if (p && p.catch) p.catch(() => {});
      });
    }
    playHeroVideo();
    document.addEventListener("astro:page-load", playHeroVideo);
  </script>
</body>
</html>
