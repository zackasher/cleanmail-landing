---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <main class="legal-content">
    <slot />
  </main>

  <style>
    .legal-content {
      max-width: 720px;
      margin: 40px auto;
      padding: 0 24px;
      color: var(--navy);
      line-height: 1.7;
    }

    .legal-content :global(h1) {
      font-size: 28px;
      font-weight: 500;
      color: var(--purple);
      margin-bottom: 24px;
      margin-top: 0;
      letter-spacing: -0.5px;
    }

    .legal-content :global(h2) {
      font-size: 20px;
      font-weight: 500;
      color: var(--navy);
      margin-top: 36px;
      margin-bottom: 12px;
    }

    .legal-content :global(h3) {
      font-size: 16px;
      font-weight: 500;
      color: var(--navy);
      margin-top: 28px;
      margin-bottom: 10px;
    }

    .legal-content :global(p) {
      font-size: 15px;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .legal-content :global(ul),
    .legal-content :global(ol) {
      margin: 12px 0 20px 24px;
      color: var(--muted);
      font-size: 15px;
    }

    .legal-content :global(li) {
      margin-bottom: 8px;
    }

    .legal-content :global(strong) {
      color: var(--navy);
      font-weight: 500;
    }

    .legal-content :global(a) {
      color: var(--purple);
      text-decoration: underline;
    }

    .legal-content :global(hr) {
      border: none;
      border-top: 1px solid var(--line);
      margin: 32px 0;
    }

    .legal-content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
      font-size: 14px;
    }

    .legal-content :global(th),
    .legal-content :global(td) {
      border: 1px solid var(--line);
      padding: 10px 12px;
      text-align: left;
      color: var(--muted);
    }

    .legal-content :global(th) {
      background: var(--card);
      color: var(--navy);
      font-weight: 500;
    }
  </style>
</BaseLayout>