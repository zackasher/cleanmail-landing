---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PhoneFrame from "../components/PhoneFrame.astro";
---
<BaseLayout title="Cleanmail: Family Inbox">
  <Hero />

  <section class="peek" id="how">
    <PhoneFrame>
      <video class="hero-video" autoplay muted loop playsinline>
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    </PhoneFrame>
  </section>
</BaseLayout>

<style>
  .peek{display:flex;justify-content:center;padding:8px 24px 88px;background:transparent}
  .screen-pad{padding:16px 12px 0}
  .scr-h{font-size:12px;color:var(--muted);text-align:center;margin-bottom:13px}
  .scr-h b{color:var(--navy);font-weight:500;font-size:14px;display:block;margin-bottom:2px}
  .person{font-size:12.5px;font-weight:500;color:#fff;background:var(--purple);padding:6px 11px;border-radius:8px;margin-bottom:7px}
  .act{font-size:10.5px;font-weight:500;color:var(--orange);margin:0 2px 5px;text-transform:uppercase;letter-spacing:.4px}
  .bullet{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:9px 11px;margin-bottom:7px;font-size:11.5px;line-height:1.42;color:var(--ink);text-align:left}
  .evt{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--line);border-left:3px solid var(--orange);border-radius:8px;padding:8px 10px;margin-bottom:7px}
  .evt .d{font-size:10.5px;font-weight:500;color:var(--orange);min-width:30px}
  .evt .t{font-size:11px;color:var(--ink)}
  .hero-video{width:100%;height:100%;object-fit:cover;display:block}
</style>
