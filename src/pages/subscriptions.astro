---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const features = [
  "Up to 8 people",
  "Up to 6 activities per person",
  "Up to 25 senders per activity",
  "Daily or weekly delivery",
  "Digest history (60 days)",
  "4 weeks of upcoming events",
  "Automatic Google Calendar sync",
];

const billing = [
  {
    q: "Is there a free version?",
    a: "There's no permanent free tier. Instead you get the whole app free for 14 days, then it's one flat price.",
  },
  {
    q: "Do I need a card to start the trial?",
    a: "Yes, a card starts the trial. Cancel any time before day 14 and you won't be charged a cent.",
  },
  {
    q: "How do I cancel?",
    a: "From inside the app or the Stripe billing portal. Cancelling takes effect at the end of your billing period, and you keep access until then.",
  },
  {
    q: "Where does billing happen?",
    a: "Securely through Stripe, handled in the app. We never see or store your full card details.",
  },
];
---
<BaseLayout
  title="Subscriptions | Cleanmail"
  description="One flat plan for Cleanmail. $6.99 a month with a 14-day free trial. No tiers, no upsells, no ads."
>
  <section class="sub">
    <p class="eyebrow">Pricing</p>
    <h1>One plan. Everything included.</h1>
    <p class="lede">One flat price. No tiers, no upsells, never an ad. Live with it free for 14 days and see if you can go back.</p>

    <div class="card">
      <span class="badge">14-day free trial</span>
      <div class="card-head">
        <span class="plan-name">Cleanmail</span>
        <span class="price"><span class="amount">$6.99</span><span class="per">/mo</span></span>
      </div>
      <p class="trial-note">Cancel anytime before it ends and you won't be charged.</p>
      <div class="divider"></div>
      <ul class="features">
        {features.map((f) => (
          <li>
            <svg class="check" viewBox="0 0 16 16" aria-hidden="true"><path d="M13 4.5 6.5 11 3 7.5" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="launch">
      <p class="launch-line">Cleanmail is coming to iPhone. Drop your email and we'll tell you the moment it's live.</p>
      <CTA />
    </div>

    <p class="fine-print">A card starts your trial, and it converts to $6.99/mo when the 14 days are up unless you cancel first. Cancel from the app or the Stripe billing portal anytime. We don't offer refunds for partial periods.</p>

    <div class="faq">
      <h2>Billing questions</h2>
      {billing.map((item) => (
        <div class="faq-item">
          <p class="faq-q">{item.q}</p>
          <p class="faq-a">{item.a}</p>
        </div>
      ))}
    </div>
  </section>

  <style>
    .sub{max-width:760px;margin:0 auto;padding:80px 24px 100px}
    .eyebrow{text-align:center;text-transform:uppercase;letter-spacing:1.5px;font-size:12.5px;font-weight:600;color:var(--purple);margin:0 0 14px}
    h1{text-align:center;font-size:clamp(30px,4.4vw,44px);font-weight:400;letter-spacing:-1px;color:var(--navy);margin:0 0 16px;line-height:1.08}
    .lede{text-align:center;max-width:540px;margin:0 auto 44px;color:var(--ink);font-size:17px;line-height:1.55}

    .card{position:relative;max-width:460px;margin:0 auto;background:var(--card);border:1px solid var(--line);border-radius:20px;padding:30px 30px 26px;box-shadow:0 18px 48px rgba(27,34,54,.07)}
    .badge{display:inline-block;background:rgba(74,111,227,.10);color:var(--purple);font-size:12.5px;font-weight:600;padding:6px 12px;border-radius:999px;margin-bottom:18px}
    .card-head{display:flex;justify-content:space-between;align-items:flex-end;gap:12px}
    .plan-name{font-size:22px;font-weight:500;color:var(--navy)}
    .price{display:flex;align-items:flex-end;gap:3px}
    .amount{font-size:40px;font-weight:300;color:var(--navy);line-height:1;letter-spacing:-1px}
    .per{font-size:15px;color:var(--muted);margin-bottom:6px}
    .trial-note{font-size:13px;color:var(--muted);margin:10px 0 0}
    .divider{height:1px;background:var(--line);margin:20px 0}
    .features{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:11px}
    .features li{display:flex;align-items:center;gap:10px;font-size:15px;color:var(--ink)}
    .check{width:16px;height:16px;color:var(--purple);flex-shrink:0}

    .launch{max-width:460px;margin:32px auto 0;text-align:center}
    .launch-line{font-size:15px;color:var(--ink);line-height:1.5;margin:0 0 18px}

    .fine-print{max-width:520px;margin:26px auto 0;text-align:center;font-size:12.5px;color:var(--muted);line-height:1.6}

    .faq{max-width:600px;margin:64px auto 0}
    .faq h2{text-align:center;font-size:22px;font-weight:500;color:var(--navy);margin:0 0 28px}
    .faq-item{padding:0 0 20px;margin-bottom:20px;border-bottom:1px solid var(--line)}
    .faq-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
    .faq-q{font-size:15.5px;font-weight:500;color:var(--navy);margin:0 0 6px}
    .faq-a{font-size:14.5px;color:var(--muted);line-height:1.55;margin:0}
  </style>
</BaseLayout>
