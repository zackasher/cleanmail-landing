---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhoneFrame from "../components/PhoneFrame.astro";
import CTA from "../components/CTA.astro";

const oldWay = [
  "Forward emails to an app, one at a time",
  "Type every date into a calendar yourself",
  "Dig through the inbox for the permission slip",
  "Miss the one email that actually mattered",
];

const newWay = [
  "Connect Gmail once, read-only",
  "It reads only the senders you pick",
  "Summarized by kid and by activity",
  "Every date on your calendar, automatically",
];
---
<BaseLayout
  title="How It Works | Cleanmail"
  description="Cleanmail reads your school, camp, and sports email and turns it into one organized digest, with every date already on your calendar. Here's how."
>
  <section class="hiw">
    <p class="eyebrow">How it works</p>
    <h1>It reads the email. You don't.</h1>
    <p class="lede">Connect your inbox once, tell it who and what matters, and Cleanmail does the reading from then on. Three steps, then it runs on its own.</p>

    <div class="steps">

      <div class="step">
        <div class="step-text">
          <span class="step-num">Step 1</span>
          <h2>Connect your Gmail</h2>
          <p>Connect your Gmail to set up your account. We never keep or sell your information ever.</p>
        </div>
        <div class="step-visual">
          <div class="connect-art">
            <svg viewBox="0 0 64 64" width="80" height="80" aria-hidden="true">
              <path d="M32 6 54 14v16c0 14-9.5 23.5-22 28C19.5 53.5 10 44 10 30V14L32 6Z" fill="none" stroke="var(--purple)" stroke-width="3" stroke-linejoin="round"/>
              <path d="M23 32l6.5 6.5L43 25" fill="none" stroke="var(--purple)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="step flip">
        <div class="step-text">
          <span class="step-num">Step 2</span>
          <h2>Tell it who and what matters</h2>
          <p>Add each person you care about and their activities you want to track. Then drop in whoever emails them.</p>
        </div>
        <div class="step-visual">
          <PhoneFrame>
            <img class="shot" src="/PeopleSetup_Sample.png" alt="Cleanmail people and activity setup screen" />
          </PhoneFrame>
        </div>
      </div>

      <div class="step">
        <div class="step-text">
          <span class="step-num">Step 3</span>
          <h2>Get your digest</h2>
          <p>Updated every day or weekly, Cleanmail will curate and organize your personal digest. The dates buried in those emails? Already on your calendar.</p>
        </div>
        <div class="step-visual">
          <PhoneFrame>
            <img class="shot" src="/Digest_Sample.png" alt="A Cleanmail digest organized by person and activity" />
          </PhoneFrame>
        </div>
      </div>

    </div>

    <div class="compare">
      <div class="col old">
        <h3>The old way</h3>
        <ul>
          {oldWay.map((item) => (
            <li>
              <svg class="ic x" viewBox="0 0 16 16" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="col new">
        <h3>With Cleanmail</h3>
        <ul>
          {newWay.map((item) => (
            <li>
              <svg class="ic check" viewBox="0 0 16 16" aria-hidden="true"><path d="M13 4.5 6.5 11 3 7.5" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="final">
      <h2>See it for yourself</h2>
      <p>Cleanmail is coming to iPhone. Drop your email and we'll tell you the moment it's live.</p>
      <CTA />
    </div>

  </section>

  <style>
    .hiw{max-width:1040px;margin:0 auto;padding:80px 24px 90px}
    .eyebrow{text-align:center;text-transform:uppercase;letter-spacing:1.5px;font-size:12.5px;font-weight:600;color:var(--purple);margin:0 0 14px}
    h1{text-align:center;font-size:clamp(30px,4.6vw,46px);font-weight:400;letter-spacing:-1.2px;color:var(--navy);margin:0 0 16px;line-height:1.08}
    .lede{text-align:center;max-width:560px;margin:0 auto;color:var(--ink);font-size:17px;line-height:1.55}

    .steps{display:flex;flex-direction:column;gap:72px;margin-top:72px}
    .step{display:flex;align-items:center;gap:56px}
    .step.flip{flex-direction:row-reverse}
    .step-text{flex:1;max-width:460px;background:#fff;border:1.5px solid rgba(74,111,227,.40);border-radius:20px;padding:24px;box-shadow:0 10px 30px rgba(27,34,54,.05)}
    .step-visual{flex:1;display:flex;justify-content:center}
    .step-num{display:inline-block;font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--teal);margin-bottom:12px}
    .step h2{position:relative;overflow:hidden;font-size:clamp(18px,2.2vw,22px);font-weight:500;color:#fff;background:var(--purple);padding:13px 20px;border-radius:14px;margin:0 0 14px;letter-spacing:-.2px;box-shadow:0 8px 20px rgba(74,111,227,.22)}
    .step h2::after{content:"";position:absolute;right:0;bottom:0;width:44px;height:44px;background:rgba(0,0,0,.15);clip-path:polygon(100% 0,100% 100%,0 100%)}
    .step p{font-size:17px;line-height:1.6;color:var(--ink);background:var(--card);border:1px solid var(--line);border-radius:16px;padding:17px 20px;margin:0;box-shadow:0 8px 22px rgba(27,34,54,.05)}
    .step-trust{font-size:13.5px;color:var(--muted)}

    .connect-art{width:220px;height:220px;border-radius:30px;background:linear-gradient(160deg,#eef2fc,#f7f9ff);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;box-shadow:0 16px 40px rgba(27,34,54,.07)}

    .ph-screen{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;background:linear-gradient(160deg,#eef2fc,#f7f9ff)}
    .ph-screen.payoff{background:linear-gradient(160deg,#e9effc,#f7f9ff)}
    .ph-tag{font-size:14px;font-weight:700;letter-spacing:2px;color:var(--purple)}
    .ph-sub{font-size:11.5px;color:var(--muted)}
    .shot{width:100%;height:100%;object-fit:cover;object-position:top center;display:block}

    .compare{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:96px}
    .col{border:1px solid var(--line);border-radius:18px;padding:28px 26px;background:#fff}
    .col.old{background:var(--card)}
    .col h3{font-size:16px;font-weight:600;margin:0 0 18px;color:var(--navy)}
    .col.old h3{color:var(--muted)}
    .col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:13px}
    .col li{display:flex;align-items:flex-start;gap:11px;font-size:15px;line-height:1.4;color:var(--ink)}
    .col.old li{color:var(--muted)}
    .ic{width:16px;height:16px;flex-shrink:0;margin-top:1px}
    .ic.x{color:#c2c9d8}
    .ic.check{color:var(--purple)}

    .final{text-align:center;margin-top:96px}
    .final h2{font-size:clamp(24px,3vw,32px);font-weight:500;color:var(--navy);margin:0 0 12px;letter-spacing:-.4px}
    .final p{font-size:16px;color:var(--muted);max-width:460px;margin:0 auto 26px;line-height:1.5}

    @media (max-width:820px){
      .step,.step.flip{flex-direction:column;text-align:center;gap:30px}
      .step-text{max-width:520px}
      .step-num{margin-left:auto;margin-right:auto}
      .step-trust{color:var(--muted)}
      .compare{grid-template-columns:1fr;margin-top:64px}
      .col li,.col.old li{text-align:left}
    }
  </style>
</BaseLayout>
