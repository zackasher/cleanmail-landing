---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const links = [
  { href: "/how-it-works", label: "How It Works" },
  { href: "/subscriptions", label: "Subscriptions" },
  { href: "/privacy", label: "Privacy" },
  { href: "/faq", label: "FAQ" },
];
---
<nav>
  <a class="wordmark" href="/" aria-label="Cleanmail home">
    <img src="/icon.png" alt="Cleanmail" class="mark" />
  </a>
  <div class="navright">
    <div class="seg">
      {links.map((l) => (
        <a href={l.href} class={`chip${path === l.href ? " active" : ""}`}>{l.label}</a>
      ))}
    </div>
    <button class="burger" id="menu-btn" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<style>
  nav{position:sticky;top:14px;z-index:50;width:calc(100% - 40px);max-width:2200px;margin:14px auto 0;display:flex;align-items:center;justify-content:space-between;padding:11px 26px;background:linear-gradient(135deg, rgba(255,255,255,.34), rgba(255,255,255,.20));backdrop-filter:blur(8px) saturate(1.2);-webkit-backdrop-filter:blur(8px) saturate(1.2);;-webkit-backdrop-filter:blur(22px) saturate(1.7);border:1px solid rgba(255,255,255,.55);border-radius:22px;box-shadow:0 12px 34px rgba(27,34,54,.10), inset 0 1px 0 rgba(255,255,255,.7)}
  .wordmark{position:relative;z-index:2;display:inline-flex;align-items:center;text-decoration:none}
  .wordmark .mark{height:40px;width:auto;display:block;filter:drop-shadow(0 1px 3px rgba(27,34,54,.16))}
  .navright{display:flex;align-items:center;gap:18px}
  .seg{display:flex;align-items:center;gap:8px}
  .chip{font-size:14px;font-weight:400;color:var(--ink);background:rgba(255,255,255,.82);border:1px solid rgba(74,111,227,.16);padding:8px 15px;border-radius:999px;text-decoration:none;transition:all .15s;white-space:nowrap}
  .chip:hover{border-color:rgba(74,111,227,.5);color:var(--purple);background:#fff}
  .chip.active{background:var(--purple);color:#fff;border-color:var(--purple);box-shadow:0 5px 14px rgba(74,111,227,.28)}
  .burger{display:none;flex-direction:column;align-items:center;justify-content:center;gap:5px;width:42px;height:42px;padding:0;background:rgba(255,255,255,.82);border:1px solid rgba(74,111,227,.16);border-radius:12px;cursor:pointer}
  .burger span{display:block;width:24px;height:2.5px;border-radius:2px}
  .burger span:nth-child(1){background:#4A6FE3}
  .burger span:nth-child(2){background:#2D4BAD}
  .burger span:nth-child(3){background:#4A6FE3}
  .mobile-menu{display:none;position:absolute;top:100%;right:14px;margin-top:10px;background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:0 14px 40px rgba(27,34,54,.12);padding:8px;min-width:200px;z-index:60}
  .mobile-menu.open{display:block}
  .mobile-menu a{display:block;padding:10px 14px;font-size:15px;color:var(--ink);text-decoration:none;border-radius:9px}
  .mobile-menu a:hover{background:var(--card);color:var(--purple)}
  @media(max-width:860px){.seg{display:none}.burger{display:flex}}
</style>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = menu.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(open));
    });
    document.addEventListener("click", () => menu.classList.remove("open"));
  }
</script>
