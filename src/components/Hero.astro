---
import CTA from "./CTA.astro";
---
<section class="hero">
  <div class="hero-inner">
    <img class="logo" src="/logo.png" alt="Cleanmail" />
    <h1>Stop reading every email,<br />just read <span class="accent">the words that matter.</span></h1>
    <p class="sub">Every newsletter, reminder, and update summarized and organized for you by person and activity, with every date already on your calendar.</p>
    <div class="actions">
      <CTA />
    </div>
    <p class="trust"><b>Read-only access.</b><span class="dot"></span>Only the senders you choose.<span class="dot"></span>We do not sell your info, you mean too much to us.</p>
  </div>
</section>

<style>
  .hero{position:relative;text-align:center;min-height:52vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:58px 24px 40px}
  .hero-inner{position:relative;z-index:1;max-width:760px;animation:rise .9s cubic-bezier(.2,.7,.2,1) both}
  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  .logo{width:clamp(220px,30vw,310px);height:auto;display:block;margin:0 auto 28px}
  h1{font-size:clamp(30px,4.6vw,50px);font-weight:400;line-height:1.1;letter-spacing:-1.2px;color:var(--navy)}
  h1 .accent{color:var(--purple)}
  .sub{margin:20px auto 0;max-width:560px;font-size:clamp(15px,1.7vw,18px);line-height:1.6;color:var(--muted);font-weight:400}
  .actions{margin-top:32px}
  .see-how{display:inline-flex;align-items:center;gap:7px;margin-top:22px;font-size:15px;font-weight:500;color:var(--purple);text-decoration:none}
  .see-how:hover{opacity:.85}
  .trust{margin-top:26px;font-size:13px;color:var(--muted);letter-spacing:.1px}
  .trust b{color:var(--ink);font-weight:500}
  .dot{display:inline-block;width:4px;height:4px;border-radius:50%;background:#cfd6e6;margin:0 9px;vertical-align:middle}
</style>
