---
import AppLink from "./AppLink.astro";
---
<AppLink />
<footer>
  <div class="footer-links">
    <a href="/privacy">Privacy Policy</a>
    <a href="/terms">Terms of Service</a>
    <a href="/support">Support</a>
  </div>
  <p class="footer-copy">© 2026 Calibrate LLC. All rights reserved.</p>
</footer>

<style>
  footer{text-align:center;padding:26px 26px 44px;background:transparent}
  .footer-links{display:flex;justify-content:center;gap:24px;margin-bottom:10px}
  .footer-links a{font-size:12px;color:var(--muted);text-decoration:none;transition:color .15s}
  .footer-links a:hover{color:var(--purple)}
  .footer-copy{font-size:12px;color:#9aa1b4}
</style>
