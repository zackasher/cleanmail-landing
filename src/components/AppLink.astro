---
import { SITE_STAGE, APP_STORE_URL } from "../config";
const launched = SITE_STAGE === "launched";
const target = launched ? APP_STORE_URL : "/coming-soon";
const top = launched ? "Download on the" : "Coming soon to the";
const cap = launched ? "Scan to download" : "Scan to learn more";
---
<section class="applink">
  <a class="store-badge" href={target} aria-label={`${top} App Store`}>
    <svg class="apple" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c-.03-2.6 2.13-3.85 2.22-3.91-1.21-1.78-3.1-2.02-3.77-2.05-1.6-.16-3.13.94-3.94.94-.81 0-2.07-.92-3.4-.9-1.75.03-3.36 1.02-4.26 2.58-1.81 3.15-.46 7.81 1.3 10.37.86 1.25 1.89 2.65 3.23 2.6 1.3-.05 1.79-.84 3.36-.84 1.56 0 2 .84 3.39.81 1.4-.02 2.28-1.27 3.14-2.53.98-1.45 1.39-2.86 1.41-2.93-.03-.01-2.72-1.04-2.75-4.15zM14.6 4.85c.72-.86 1.2-2.07 1.07-3.27-1.03.04-2.28.68-3.02 1.54-.66.76-1.24 1.99-1.08 3.16 1.15.09 2.32-.58 3.03-1.43z"/></svg>
    <span class="badge-text"><small>{top}</small><strong>App Store</strong></span>
  </a>
  <a class="qr-wrap" href={target} tabindex="-1">
    <img src="/app-qr.png" alt="" width="96" height="96" />
    <span class="qr-cap">{cap}</span>
  </a>
</section>
<style>
  .applink{display:flex;align-items:center;justify-content:center;gap:24px;padding:8px 24px 30px;flex-wrap:wrap}
  .store-badge{display:inline-flex;align-items:center;gap:11px;background:#000;color:#fff;border-radius:13px;padding:10px 20px 10px 16px;text-decoration:none;transition:transform .15s,box-shadow .15s;box-shadow:0 8px 22px rgba(0,0,0,.18)}
  .store-badge:hover{transform:translateY(-1px);box-shadow:0 12px 28px rgba(0,0,0,.26)}
  .apple{width:27px;height:27px;flex:0 0 auto;margin-top:-2px}
  .badge-text{display:flex;flex-direction:column;line-height:1.08;text-align:left}
  .badge-text small{font-size:11px;font-weight:400;opacity:.92}
  .badge-text strong{font-size:19px;font-weight:600;letter-spacing:.2px}
  .qr-wrap{display:flex;flex-direction:column;align-items:center;gap:7px;text-decoration:none}
  .qr-wrap img{border:1px solid var(--line);border-radius:12px;background:#fff;padding:6px;display:block}
  .qr-cap{font-size:11px;color:var(--muted)}
  @media(max-width:560px){.qr-wrap{display:none}}
</style>
